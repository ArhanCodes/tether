{
  "expo": {
    "name": "Tether",
    "slug": "tether",
    "scheme": "tether",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#10211d"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Tether to convert the patient's speech into text.",
        "NSMicrophoneUsageDescription": "Allow Tether to hear the patient's question.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.tetherhealth.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#10211d",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.tetherhealth.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Tether to hear the patient's question.",
          "speechRecognitionPermission": "Allow Tether to convert the patient's speech into text."
        }
      ],
      "expo-audio"
    ]
  }
}
